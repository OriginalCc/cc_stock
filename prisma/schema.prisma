// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── 做 T 策略因子 & 逻辑 ──────────────────────────────

model StrategyFactor {
  id          String   @id @default(cuid())
  name        String                    // 因子名称 e.g. "MACD金叉", "量价背离"
  category    String                    // 类别: "MACD", "VWAP", "VOLUME", "VOLUME_PATTERN", "MOMENTUM", "DIVERGENCE", "STOPLOSS", "RSI", "BOLL", "SUPPORT", "TIME_WINDOW", "SPREAD", "REGIME"
  signalType  String                    // "buy" | "sell" | "stoploss"
  description String                    // 因子描述
  params      String   @default("{}")   // JSON 参数
  enabled     Boolean  @default(true)   // 是否启用
  priority    Int      @default(0)      // 优先级(越大越先判断)
  strength    String   @default("medium") // 默认信号强度
  tMode       String   @default("正T")   // 做T模式: "正T" | "反T"
  timeWindow  String   @default("any")   // 适用时间窗口: "any" | "sell_window" | "buy_window"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StrategyLogic {
  id          String   @id @default(cuid())
  name        String                    // 逻辑名称
  description String                    // 逻辑描述
  logicOrder  Int      @default(0)      // 执行顺序
  isActive    Boolean  @default(true)   // 是否激活
  category    String   @default("general") // 逻辑类别
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── 策略指标参数配置 ──────────────────────────────────

model StrategyConfig {
  id            String   @id @default(cuid())
  indicatorKey  String                      // 指标键名: "macd", "vwap", "rsi", "boll", "volume"
  paramKey      String                      // 参数键名: "fastPeriod", "deviationSell", "rsiPeriod" etc.
  value         String                      // 参数值 (stored as string, parsed on read)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([indicatorKey, paramKey]) // 每个指标+参数组合唯一
}

// ── 板块轮动预测记录 ────────────────────────────────────

model SectorPredictionRecord {
  id              String   @id @default(cuid())
  predictDate     String                      // 预测日期 YYYY-MM-DD (预测当日)
  sectorCode      String                      // 板块代码 e.g. "BK0896"
  sectorName      String                      // 板块名称 e.g. "白酒"
  category        String                      // 预测类型: capital_gathering | pullback_recovery | momentum_shift | adjacent_chain
  categoryLabel   String                      // 预测类型标签: 资金蓄势 | 回调企稳 | 动能切换 | 产业链联动
  score           Int                         // 预测分数 0-100
  reasons         String                      // 预测理由 (JSON array string)
  predictChange   Float                       // 预测当日涨跌幅%
  mainNetInflow   Float                       // 预测当日主力净流入
  turnover        Float                       // 预测当日换手率
  // ── 次日验证结果 ──
  actualChange    Float?                      // 次日实际涨跌幅%
  actualMainNet   Float?                      // 次日实际主力净流入
  isVerified      Boolean  @default(false)    // 是否已验证
  verifiedAt      DateTime?                   // 验证时间
  // ── 评价 ──
  isCorrect       Boolean?                    // 预测是否正确 (次日涨跌幅>0视为正确)
  createdAt       DateTime @default(now())

  @@unique([predictDate, sectorCode]) // 同一天同一板块只记录一次
}

// ── 历史选股验证记录 ────────────────────────────────────

model ScreenerHistoryRecord {
  id                String   @id @default(cuid())
  recordDate        String                     // 选股日期 YYYY-MM-DD
  recordTime        String                     // 选股时间 HH:mm (整点/半点)
  screenerType      String   @default("stock") // 选股类型: stock | intraday | early | low_open | limit_up
  sectorName        String                     // 板块名/选股策略名
  stockCount        Int                        // 选出股票数量
  stocksJson        String                     // JSON array of stocks
  filtersJson       String   @default("{}")    // JSON 筛选条件
  // ── 次日验证 ──
  avgNextDayChange  Float    @default(0)       // 次日平均涨跌幅%
  nextDayChangesJson String  @default("{}")    // JSON Record<symbol, change>
  isVerified        Boolean  @default(false)   // 是否已验证
  verifiedAt        DateTime?
  // ── 多日验证 ──
  day3ChangesJson   String   @default("{}")    // JSON Record<symbol, change> 3日后涨幅
  day5ChangesJson   String   @default("{}")    // JSON Record<symbol, change> 5日后涨幅
  avgDay3Change     Float    @default(0)       // 3日平均涨幅
  avgDay5Change     Float    @default(0)       // 5日平均涨幅
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([recordDate, recordTime, sectorName]) // 同一天同一时间同一板块只记录一次
}

// ── 应用配置（密码等） ────────────────────────────────────

model AppConfig {
  id    String @id @default(cuid())
  key   String @unique                // 配置键名: "app_password"
  value String                       // 配置值
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── 板块信息缓存（避免重复调用东方财富API） ──────────────────

model SectorInfoCache {
  id         String   @id @default(cuid())
  symbol     String   @unique                // 股票代码 e.g. "600519"
  sectorCode String                          // 板块代码 e.g. "BK0896"
  sectorName String                          // 板块名称 e.g. "白酒"
  quoteId    String   @default("")            // 东方财富行情ID e.g. "90.BK0896"
  market     Int      @default(90)            // 市场代码 (板块固定为90)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}